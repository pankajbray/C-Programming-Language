/* Ramesh’s basic salary is input through the keyboard.
His dearness allowance is 40% of basic salary and house rent allowance is 20% of basic salary.
Write a program to calculate gross salary. */
#include <stdio.h>
int main () {
    float bs, hra, da, gs;
    printf("Enter Basic Salary: ");
    scanf("%f", &bs);
    da = 0.4 * bs;
    hra = 0.2 * bs;
    gs = bs + da + hra;

    printf("Gross Salary = %.2f\n ", gs);
    return 0;
}
